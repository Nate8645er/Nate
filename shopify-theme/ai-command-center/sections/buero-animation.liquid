{% comment %}
  KI-Welt: eine bunte animierte Stadt. Verschiedenfarbige Gebäude mit
  Neon-Schildern (CODING, MARKETING, ANALYSE …), leuchtende Fenster und
  bunte Roboter-Figuren, die durch die Welt laufen. Einzigartige
  Animation, reines CSS (transform/opacity).
{% endcomment %}

<section class="acc-section acc-welt-sec">
  <div class="acc-wrap">
    <div class="acc-shead acc-reveal">
      <span class="acc-micro">{{ section.settings.label }}</span>
      <h2>{{ section.settings.titel }}</h2>
      <p class="acc-welt__intro">{{ section.settings.intro }}</p>
    </div>

    <div class="acc-welt acc-reveal">
      {% assign labels = "HAUPTQUARTIER,WERKSTATT,ANALYSE,QUALITÄT,MARKETING,RESEARCH,CODING,FINANZEN" | split: "," %}
      {% assign farben = "#ff8c2a,#3b82f6,#06b6d4,#eab308,#ec4899,#8b5cf6,#22c55e,#14b8a6" | split: "," %}
      {% assign hoehen = "210,165,190,150,185,200,170,160" | split: "," %}
      <div class="acc-welt__city">
        {% for lb in labels %}
          {% assign i = forloop.index0 %}
          {% assign left = i | times: 94 | divided_by: 8 | plus: 3 %}
          <div class="acc-bld acc-bld--work" style="left: {{ left }}%; width: 9.6%; height: {{ hoehen[i] }}px; --c: {{ farben[i] }};">
            <span class="acc-bld__sign">{{ lb }}</span>
            <div class="acc-bld__win">
              {% assign wins = hoehen[i] | minus: 30 | divided_by: 18 | times: 3 %}
              {% for w in (1..wins) %}<i></i>{% endfor %}
            </div>
          </div>
        {% endfor %}
      </div>

      {% assign botcol = "#ff8c2a,#3b82f6,#22c55e,#ec4899,#8b5cf6,#06b6d4,#eab308,#14b8a6,#f43f5e,#a3e635,#fb923c,#38bdf8,#22c55e,#ec4899" | split: "," %}
      {% for c in botcol %}
        {% assign i = forloop.index0 %}
        {% assign lane = i | times: 37 | modulo: 60 | plus: 4 %}
        {% assign dauer = i | times: 5 | modulo: 9 | plus: 8 %}
        {% assign delay = i | times: 13 | modulo: 16 %}
        {% assign rechts = i | modulo: 2 %}
        <div class="acc-wbot {% if rechts == 0 %}acc-walk-r{% else %}acc-walk-l{% endif %}"
             style="bottom: {{ lane }}px; --c: {{ c }}; animation-duration: {{ dauer }}s; animation-delay: -{{ delay }}s;">
          <span class="acc-wb-inner"><span class="acc-wb-head"></span><span class="acc-wb-body"></span><span class="acc-wb-legs"><i></i><i></i></span></span>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .acc-welt__intro { max-width: 640px; margin: var(--sp-3) auto 0; color: var(--acc-text-dim); }
  .acc-welt {
    position: relative; height: 380px; margin-top: var(--sp-6); border-radius: 22px; overflow: hidden;
    border: 1px solid rgba(255,255,255,0.1);
    background:
      radial-gradient(50rem 24rem at 20% 0%, rgba(139,92,246,.28), transparent 60%),
      radial-gradient(46rem 22rem at 80% 8%, rgba(59,130,246,.22), transparent 60%),
      radial-gradient(40rem 22rem at 55% 100%, rgba(236,72,153,.16), transparent 60%),
      linear-gradient(180deg, #120a26 0%, #0e1230 45%, #0a1024 100%);
  }
  .acc-welt::before {
    content: ""; position: absolute; inset: 0;
    background-image:
      radial-gradient(1.5px 1.5px at 12% 22%, rgba(255,255,255,.8), transparent),
      radial-gradient(1.5px 1.5px at 32% 12%, rgba(255,255,255,.6), transparent),
      radial-gradient(1.5px 1.5px at 58% 26%, rgba(255,255,255,.7), transparent),
      radial-gradient(1.5px 1.5px at 76% 14%, rgba(255,255,255,.55), transparent),
      radial-gradient(1.5px 1.5px at 90% 30%, rgba(255,255,255,.7), transparent);
    animation: acc-tw 4s ease-in-out infinite;
  }
  @keyframes acc-tw { 0%,100% { opacity:.7; } 50% { opacity:1; } }
  .acc-welt::after {
    content: ""; position: absolute; left:0; right:0; bottom:0; height: 84px;
    background: repeating-linear-gradient(90deg, transparent 0 46px, rgba(255,255,255,.05) 46px 60px), linear-gradient(180deg, #241a52, #0f0c26);
    border-top: 2px solid rgba(255,255,255,.14);
  }
  .acc-welt__city { position: absolute; left:0; right:0; bottom: 74px; height: 250px; }
  .acc-bld {
    position: absolute; bottom: 0; border-radius: 8px 8px 0 0;
    background: linear-gradient(180deg, color-mix(in srgb, var(--c) 42%, #0c0a1e), #0c0a1e 92%);
    border: 1px solid color-mix(in srgb, var(--c) 55%, transparent);
    box-shadow: 0 0 30px -6px color-mix(in srgb, var(--c) 60%, transparent), inset 0 1px 0 rgba(255,255,255,.12);
  }
  .acc-bld__win { position: absolute; inset: 14px 10px 10px 10px; display: grid; grid-template-columns: repeat(3,1fr); gap: 5px 6px; grid-auto-rows: 9px; }
  .acc-bld__win i { border-radius: 1.5px; background: color-mix(in srgb, var(--c) 70%, #fff 8%); opacity:.28; animation: acc-win 1.5s ease-in-out infinite; }
  .acc-bld__win i:nth-child(3n) { animation-delay: .4s; }
  .acc-bld__win i:nth-child(4n) { animation-delay: .8s; }
  @keyframes acc-win { 0%,100% { opacity:.25; } 50% { opacity:.95; } }
  .acc-bld__sign {
    position: absolute; top: -13px; left: 50%; transform: translateX(-50%); padding: 3px 9px; border-radius: 999px;
    font-family: var(--acc-mono); font-size: 9px; font-weight: 700; letter-spacing: .12em; white-space: nowrap; color: #fff;
    background: color-mix(in srgb, var(--c) 85%, #000); box-shadow: 0 0 14px color-mix(in srgb, var(--c) 75%, transparent), inset 0 1px 0 rgba(255,255,255,.3);
  }
  /* Roboter */
  .acc-wbot { position: absolute; z-index: 4; width: 28px; height: 36px;
    filter: drop-shadow(0 0 7px color-mix(in srgb, var(--c) 75%, transparent)) drop-shadow(0 4px 4px rgba(0,0,0,.5));
    animation-timing-function: linear; animation-iteration-count: infinite; }
  .acc-walk-r { animation-name: acc-wr; }
  .acc-walk-l { animation-name: acc-wl; }
  @keyframes acc-wr { from { left: -6%; } to { left: 106%; } }
  @keyframes acc-wl { from { left: 106%; transform: scaleX(-1); } to { left: -6%; transform: scaleX(-1); } }
  .acc-wb-inner { display:block; animation: acc-bob .5s ease-in-out infinite; }
  @keyframes acc-bob { 0%,100% { transform: translateY(0);} 50% { transform: translateY(-1.5px);} }
  .acc-wb-head { display:block; position: relative; width: 18px; height: 15px; margin: 0 auto; border-radius: 5px 5px 4px 4px; background: linear-gradient(var(--c), color-mix(in srgb, var(--c) 60%, #000)); box-shadow: inset 0 1px 0 rgba(255,255,255,.4); }
  .acc-wb-head::before { content:""; position:absolute; top:-6px; left:50%; width:2.5px; height:6px; transform:translateX(-50%); background:var(--c); border-radius:1px; box-shadow:0 -2px 7px var(--c); }
  .acc-wb-head::after { content:""; position:absolute; top:5px; left:3.5px; width:4px; height:4px; border-radius:50%; background:#fff; box-shadow:6px 0 0 #fff, 0 0 5px rgba(255,255,255,.8); }
  .acc-wb-body { display:block; width: 20px; height: 15px; margin: 1px auto 0; border-radius: 5px; background: linear-gradient(150deg, var(--c), color-mix(in srgb, var(--c) 55%, #000)); box-shadow: inset 0 1px 0 rgba(255,255,255,.35); }
  .acc-wb-legs { display:flex; justify-content:center; gap:3px; margin-top:1px; }
  .acc-wb-legs i { width:4px; height:6px; border-radius:1px; background:#1a1533; animation: acc-step .3s ease-in-out infinite; }
  .acc-wb-legs i:last-child { animation-direction: reverse; }
  @keyframes acc-step { 50% { transform: translateY(-2px);} }
  .acc-wbot::after { content:""; position:absolute; bottom:-2px; left:50%; width:20px; height:4px; transform:translateX(-50%); border-radius:50%; background:rgba(0,0,0,.5); filter: blur(1px); }
  @media (max-width: 700px) { .acc-welt { height: 320px; } }
  @media (prefers-reduced-motion: reduce) { .acc-welt::before, .acc-wbot, .acc-wb-inner, .acc-wb-legs i, .acc-bld__win i { animation: none !important; } }
</style>

{% schema %}
{
  "name": "KI-Welt Animation",
  "settings": [
    { "type": "text", "id": "label", "label": "Micro-Label", "default": "IHRE BELEGSCHAFT LEBT" },
    { "type": "text", "id": "titel", "label": "Titel", "default": "Eine ganze KI-Stadt, die für Sie arbeitet." },
    { "type": "textarea", "id": "intro", "label": "Intro", "default": "Jede Abteilung ein eigenes Gebäude – Coding, Marketing, Analyse, Finanzen und mehr. Ihre bunte KI-Belegschaft läuft durch die Welt und erledigt Auftrag für Auftrag. Kein Chatbot." }
  ],
  "presets": [{ "name": "KI-Welt Animation" }]
}
{% endschema %}
