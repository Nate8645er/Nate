{% comment %}
  Shop-Trailer: kurzes Video (~40s), das das AI Command Center in einem
  Blick erklaert. Klick-zum-Abspielen mit Poster; laedt erst bei Klick,
  bremst also die Startseite nicht. Reines HTML/CSS/JS, keine Fremd-Skripte.
{% endcomment %}

<section class="acc-section acc-trailer">
  <div class="acc-wrap">
    <div class="acc-shead acc-reveal" style="text-align:center">
      <span class="acc-micro">{{ section.settings.label | escape }}</span>
      <h2>{{ section.settings.titel | escape }}</h2>
      <p class="acc-trailer__sub">{{ section.settings.text | escape }}</p>
    </div>

    <div class="acc-trailer__frame acc-reveal" data-abovid>
      <div class="acc-trailer__glow" aria-hidden="true"></div>
      <video
        class="acc-trailer__video"
        preload="none"
        playsinline
        controls
        poster="{{ section.settings.poster | default: 'acc-trailer-poster.jpg' | asset_url }}"
      >
        <source src="{{ section.settings.video | default: 'acc-trailer.mp4' | asset_url }}" type="video/mp4">
      </video>
      <button class="acc-trailer__play" type="button" aria-label="Trailer abspielen">
        <span class="acc-trailer__pbtn">
          <svg viewBox="0 0 24 24" width="34" height="34" aria-hidden="true"><path d="M8 5v14l11-7z" fill="currentColor"/></svg>
        </span>
        <span class="acc-trailer__ptext">{{ section.settings.play_label | escape }}</span>
      </button>
    </div>
  </div>
</section>

<style>
  .acc-trailer__sub { margin: var(--sp-3) auto 0; max-width: 640px; color: var(--acc-text-dim); font-size: var(--fs-lg); }
  .acc-trailer__frame {
    position: relative;
    margin: var(--sp-7) auto 0;
    max-width: 940px;
    border-radius: var(--acc-radius-lg);
    overflow: hidden;
    border: 1px solid var(--acc-line);
    box-shadow: 0 30px 80px -30px rgba(120, 80, 20, 0.4);
    background: #000;
    aspect-ratio: 16 / 9;
  }
  .acc-trailer__glow {
    position: absolute; inset: -2px;
    background: var(--acc-grad);
    filter: blur(38px); opacity: .35; z-index: -1;
  }
  .acc-trailer__video { display: block; width: 100%; height: 100%; object-fit: cover; }
  .acc-trailer__play {
    position: absolute; inset: 0;
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 14px;
    background: linear-gradient(0deg, rgba(20,12,4,0.35), rgba(20,12,4,0.15));
    border: 0; cursor: pointer; color: #fff;
    transition: background .2s ease;
  }
  .acc-trailer__play:hover { background: linear-gradient(0deg, rgba(20,12,4,0.25), rgba(20,12,4,0.05)); }
  .acc-trailer__pbtn {
    width: 84px; height: 84px; border-radius: 50%;
    background: var(--acc-grad);
    display: flex; align-items: center; justify-content: center; color: #fff;
    box-shadow: 0 12px 34px -8px rgba(255,110,30,0.7);
    transform: translateZ(0);
    animation: accPulse 2.4s ease-in-out infinite;
  }
  .acc-trailer__play:hover .acc-trailer__pbtn { transform: scale(1.06); }
  .acc-trailer__ptext { font-weight: 700; font-size: var(--fs-sm); text-shadow: 0 2px 10px rgba(0,0,0,.4); }
  .acc-trailer__frame.is-playing .acc-trailer__play { display: none; }
  @keyframes accPulse {
    0%, 100% { box-shadow: 0 12px 34px -8px rgba(255,110,30,0.7), 0 0 0 0 rgba(255,140,42,0.5); }
    50% { box-shadow: 0 12px 34px -8px rgba(255,110,30,0.7), 0 0 0 16px rgba(255,140,42,0); }
  }
  @media (prefers-reduced-motion: reduce) { .acc-trailer__pbtn { animation: none; } }
</style>

{%- comment -%} Abspiel-Logik teilt sich die gemeinsame [data-abovid]-Steuerung in theme.js. {%- endcomment -%}

{% schema %}
{
  "name": "Shop-Trailer",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "label", "label": "Micro-Label", "default": "// IN 40 SEKUNDEN ERKLÄRT" },
    { "type": "text", "id": "titel", "label": "Überschrift", "default": "Sehen Sie Ihre KI-Abteilung in Aktion" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Vom Auftrag zur fertigen Datei, KI-Chat mit Browser und Quellen, sechs Stufen für jede Firmengrösse." },
    { "type": "text", "id": "play_label", "label": "Play-Text", "default": "Trailer ansehen" },
    { "type": "text", "id": "video", "label": "Video-Datei (asset)", "default": "acc-trailer.mp4" },
    { "type": "text", "id": "poster", "label": "Poster-Bild (asset)", "default": "acc-trailer-poster.jpg" }
  ],
  "presets": [{ "name": "Shop-Trailer" }]
}
{% endschema %}
