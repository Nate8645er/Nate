{%- assign coll = collections[section.settings.collection] -%}
<section class="acc-section acc-produkt-grid" id="abos">
  <div class="acc-wrap">
    <div class="acc-shead">
      <p class="acc-micro">{{ section.settings.eyebrow | escape }}</p>
      <h2>{{ section.settings.heading | escape }}</h2>
    </div>

    {%- if coll != blank and coll.products.size > 0 -%}
      <div class="acc-products">
        {%- for product in coll.products limit: section.settings.limit -%}
          <article class="acc-panel acc-corner acc-card">
            <span class="acc-c1" aria-hidden="true"></span>
            <span class="acc-c2" aria-hidden="true"></span>
            <a class="acc-card__media" href="{{ product.url }}">
              {%- if product.tags contains 'bestseller' -%}<span class="acc-badge">Bestseller</span>{%- endif -%}
              {%- if product.featured_media -%}
                {{ product.featured_media | image_url: width: 640 | image_tag: loading: 'lazy', alt: product.title | escape }}
              {%- else -%}
                <div class="acc-card__ph">// KEIN BILD</div>
              {%- endif -%}
            </a>
            <div class="acc-card__body">
              <h3 class="acc-card__title"><a href="{{ product.url }}">{{ product.title | escape }}</a></h3>
              <div class="acc-card__price">ab {{ product.price | money }}</div>
              <div class="acc-card__cta">
                <a class="acc-btn acc-btn--block" href="{{ product.url }}">Details</a>
              </div>
            </div>
          </article>
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="acc-panel acc-corner acc-empty">
        <span class="acc-c1" aria-hidden="true"></span>
        <span class="acc-c2" aria-hidden="true"></span>
        <p class="acc-micro">// KOLLEKTION WAEHLEN</p>
        <p>Bitte im Theme-Editor eine Kollektion zuweisen.</p>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Produkt-Grid",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Micro-Label", "default": "// VERFUEGBARE ABOS" },
    { "type": "text", "id": "heading", "label": "Ueberschrift", "default": "Waehlen Sie Ihr Kommando-Level" },
    { "type": "collection", "id": "collection", "label": "Kollektion" },
    { "type": "range", "id": "limit", "label": "Max. Produkte", "min": 3, "max": 12, "step": 1, "default": 6 }
  ],
  "presets": [{ "name": "Produkt-Grid" }]
}
{% endschema %}
