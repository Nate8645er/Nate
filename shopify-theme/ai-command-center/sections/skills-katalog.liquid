<style>
  .acc-skat__intro { max-width: 680px; margin: var(--sp-3) auto 0; color: var(--acc-text-dim); }
  .acc-skat__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--sp-5);
    margin-top: var(--sp-7);
  }
  .acc-skat__gruppe { padding: var(--sp-6); border-radius: var(--acc-radius-lg); }
  .acc-skat__gruppe h3 { margin-bottom: var(--sp-4); }
  .acc-skat__skill { padding: var(--sp-3) 0; border-top: 1px solid rgba(39,33,26,0.07); }
  .acc-skat__skill:first-of-type { border-top: 0; }
  .acc-skat__kopf { display: flex; align-items: center; justify-content: space-between; gap: var(--sp-2); }
  .acc-skat__skill code {
    font-family: var(--acc-mono);
    font-size: 13px;
    font-weight: 700;
    color: var(--acc-amber);
  }
  .acc-skat__badge {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--acc-text-dim);
    border: 1px solid rgba(39,33,26,0.14);
    border-radius: 999px;
    padding: 2px 10px;
    white-space: nowrap;
  }
  .acc-skat__skill strong { display: block; margin-top: 4px; }
  .acc-skat__skill p { margin: 2px 0 0; font-size: var(--fs-sm); color: var(--acc-text-dim); }
  @media (max-width: 860px) { .acc-skat__grid { grid-template-columns: 1fr; } }
</style>

