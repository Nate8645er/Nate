<section class="acc-section acc-cart-section">
  <div class="acc-wrap acc-cart">
    <p class="acc-micro">// WARENKORB</p>
    <h1 style="margin:12px 0 28px;">Ihr Warenkorb</h1>

    {%- if cart.item_count > 0 -%}
      {%- form 'cart', cart -%}
        {%- for item in cart.items -%}
          <div class="acc-cart__row">
            {%- if item.image -%}
              <img src="{{ item.image | image_url: width: 144 }}" alt="{{ item.product.title | escape }}" loading="lazy">
            {%- endif -%}
            <div class="acc-cart__meta">
              <a href="{{ item.url }}">{{ item.product.title | escape }}</a>
              {%- unless item.variant.title contains 'Default' -%}
                <div class="acc-micro">{{ item.variant.title | escape }}</div>
              {%- endunless -%}
              <div class="acc-micro">Menge {{ item.quantity }} &middot; {{ item.final_line_price | money }}</div>
            </div>
          </div>
        {%- endfor -%}

        <div class="acc-cart__foot">
          <div class="acc-cart__total">Total: {{ cart.total_price | money }}</div>
          <div style="display:flex;gap:12px;flex-wrap:wrap;">
            <button type="submit" name="update" class="acc-btn acc-btn--ghost">Aktualisieren</button>
            <button type="submit" name="checkout" class="acc-btn">Zur Kasse</button>
          </div>
        </div>
        <p class="acc-micro" style="margin-top:14px;">Versand und Steuern werden an der Kasse berechnet.</p>
      {%- endform -%}
    {%- else -%}
      <div class="acc-panel acc-corner acc-empty">
        <span class="acc-c1" aria-hidden="true"></span>
        <span class="acc-c2" aria-hidden="true"></span>
        <p class="acc-micro">// LEER</p>
        <p>Ihr Warenkorb ist leer.</p>
        <a class="acc-btn" href="{{ routes.all_products_collection_url }}">Abos ansehen</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Warenkorb",
  "tag": "section",
  "settings": []
}
{% endschema %}
