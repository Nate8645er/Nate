{%- comment -%} Generische Text-Section für Content-Seiten und Zwischentexte {%- endcomment -%}
<section class="rich-text-section section{% if section.settings.soft_bg %} section--soft{% endif %}">
  <div class="page-width page-width--narrow reveal{% if section.settings.centered %} text-center{% endif %}">
    {%- if section.settings.eyebrow != blank -%}<p class="section__eyebrow">{{ section.settings.eyebrow | escape }}</p>{%- endif -%}
    {%- if section.settings.title != blank -%}<h2 class="section__title">{{ section.settings.title | escape }}</h2>{%- endif -%}
    <div class="rte">{{ section.settings.text }}</div>
    {%- if section.settings.cta_label != blank -%}
      <a href="{{ section.settings.cta_link }}" class="btn btn--primary">{{ section.settings.cta_label | escape }}</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Text",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Overline" },
    { "type": "text", "id": "title", "label": "Titel", "default": "Überschrift" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Text hier einfügen.</p>" },
    { "type": "text", "id": "cta_label", "label": "Button-Text" },
    { "type": "url", "id": "cta_link", "label": "Button-Link" },
    { "type": "checkbox", "id": "centered", "label": "Zentriert", "default": false },
    { "type": "checkbox", "id": "soft_bg", "label": "Abgesetzter Hintergrund", "default": false }
  ],
  "presets": [{ "name": "Text" }]
}
{% endschema %}
