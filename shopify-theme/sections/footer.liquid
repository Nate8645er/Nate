{%- comment -%}
  Footer: Newsletter, Menüs (Shop / Hilfe / Rechtliches), Social Media,
  Zahlungsarten, Trust-Zeile. Menüs im Admin unter Navigation pflegen.
{%- endcomment -%}
<footer class="footer">
  <div class="page-width">

    <div class="footer__newsletter reveal">
      <div>
        <h2 class="footer__newsletter-title">{{ section.settings.newsletter_title | escape }}</h2>
        <p class="footer__newsletter-text">{{ section.settings.newsletter_text | escape }}</p>
      </div>
      {%- form 'customer', class: 'newsletter-form' -%}
        {%- if form.posted_successfully? -%}
          <p class="newsletter-form__success">{% render 'icon', name: 'check' %} {{ 'newsletter.success' | t }}</p>
        {%- else -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="newsletter-form__row">
            <label class="visually-hidden" for="FooterEmail">{{ 'newsletter.email' | t }}</label>
            <input id="FooterEmail" type="email" name="contact[email]" class="input" placeholder="{{ 'newsletter.email' | t }}" required autocomplete="email">
            <button type="submit" class="btn btn--accent">{{ 'newsletter.submit' | t }}</button>
          </div>
          {%- if form.errors -%}<p class="form-error">{{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}</p>{%- endif -%}
        {%- endif -%}
      {%- endform -%}
    </div>

    <div class="footer__grid">
      <div class="footer__brand">
        {%- if settings.logo -%}
          {{ settings.logo | image_url: width: 300 | image_tag: loading: 'lazy', width: settings.logo_width, class: 'footer__logo', alt: shop.name }}
        {%- else -%}
          <p class="footer__logo-text">{{ shop.name }}</p>
        {%- endif -%}
        <p class="footer__about">{{ section.settings.about_text | escape }}</p>
        <ul class="footer__social" role="list">
          {%- if settings.social_instagram != blank -%}<li><a href="{{ settings.social_instagram }}" target="_blank" rel="noopener" aria-label="Instagram">{% render 'icon', name: 'instagram' %}</a></li>{%- endif -%}
          {%- if settings.social_facebook != blank -%}<li><a href="{{ settings.social_facebook }}" target="_blank" rel="noopener" aria-label="Facebook">{% render 'icon', name: 'facebook' %}</a></li>{%- endif -%}
          {%- if settings.social_tiktok != blank -%}<li><a href="{{ settings.social_tiktok }}" target="_blank" rel="noopener" aria-label="TikTok">{% render 'icon', name: 'tiktok' %}</a></li>{%- endif -%}
          {%- if settings.social_youtube != blank -%}<li><a href="{{ settings.social_youtube }}" target="_blank" rel="noopener" aria-label="YouTube">{% render 'icon', name: 'youtube' %}</a></li>{%- endif -%}
          {%- if settings.social_pinterest != blank -%}<li><a href="{{ settings.social_pinterest }}" target="_blank" rel="noopener" aria-label="Pinterest">{% render 'icon', name: 'pinterest' %}</a></li>{%- endif -%}
        </ul>
      </div>

      {%- for block in section.blocks -%}
        <nav class="footer__col" {{ block.shopify_attributes }} aria-label="{{ block.settings.heading | escape }}">
          <h3 class="footer__heading">{{ block.settings.heading | escape }}</h3>
          <ul class="footer__links" role="list">
            {%- for link in block.settings.menu.links -%}
              <li><a href="{{ link.url }}">{{ link.title | escape }}</a></li>
            {%- endfor -%}
          </ul>
        </nav>
      {%- endfor -%}
    </div>

    <div class="footer__bottom">
      <p class="footer__copyright">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ 'general.all_rights_reserved' | t }}</p>
      {%- if section.settings.show_payment_icons -%}
        <ul class="footer__payments" role="list" aria-label="{{ 'general.payment_methods' | t }}">
          {%- for type in shop.enabled_payment_types -%}
            <li>{{ type | payment_type_svg_tag: class: 'payment-icon' }}</li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "newsletter_title", "label": "Newsletter-Titel", "default": "10% Rabatt auf deine erste Bestellung" },
    { "type": "text", "id": "newsletter_text", "label": "Newsletter-Text", "default": "Melde dich an und erhalte exklusive Angebote direkt in dein Postfach." },
    { "type": "textarea", "id": "about_text", "label": "Über den Shop (Kurztext)", "default": "Premium-Produkte, sorgfältig ausgewählt und schnell geliefert. Mit 30 Tagen Geld-zurück-Garantie." },
    { "type": "checkbox", "id": "show_payment_icons", "label": "Zahlungsarten anzeigen", "default": true }
  ],
  "blocks": [
    {
      "type": "link_column",
      "name": "Menü-Spalte",
      "settings": [
        { "type": "text", "id": "heading", "label": "Überschrift", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menü" }
      ]
    }
  ],
  "max_blocks": 3
}
{% endschema %}
