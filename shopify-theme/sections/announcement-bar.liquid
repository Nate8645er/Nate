{%- comment -%} Ankündigungsleiste: rotierende Botschaften (USP / Gratisversand / Aktion) {%- endcomment -%}
{%- if section.blocks.size > 0 -%}
<div class="announcement" style="background: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }};" data-announcement>
  <div class="announcement__track">
    {%- for block in section.blocks -%}
      <p class="announcement__item{% if forloop.first %} is-active{% endif %}" {{ block.shopify_attributes }}>
        {%- if block.settings.link != blank -%}
          <a href="{{ block.settings.link }}">{{ block.settings.text | escape }}</a>
        {%- else -%}
          {{ block.settings.text | escape }}
        {%- endif -%}
      </p>
    {%- endfor -%}
  </div>
</div>
{%- endif -%}

{% schema %}
{
  "name": "Ankündigungsleiste",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Hintergrund", "default": "#080B20" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#F1F3FF" }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Botschaft",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Versand aus EU-Lager mit Sendungsverfolgung" },
        { "type": "url", "id": "link", "label": "Link (optional)" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Ankündigungsleiste",
      "blocks": [
        { "type": "announcement", "settings": { "text": "Versand aus EU-Lager mit Sendungsverfolgung" } },
        { "type": "announcement", "settings": { "text": "30 Tage Geld-zurück-Garantie" } },
        { "type": "announcement", "settings": { "text": "Sicher bezahlen mit TWINT, Karte & PayPal" } }
      ]
    }
  ]
}
{% endschema %}
