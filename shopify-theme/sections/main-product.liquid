{%- comment -%}
  Produktseite: Galerie mit Thumbnails, Bewertung (Metafield reviews.rating),
  Preis mit Streichpreis, Variantenwahl, Menge, Add-to-Cart + Dynamic Checkout,
  USP-Checkliste, Accordion-Blöcke (Beschreibung, Versand, Garantie),
  Sticky Add-to-Cart-Leiste (mobil & Desktop), Product-JSON-LD.
{%- endcomment -%}
{%- liquid
  assign current_variant = product.selected_or_first_available_variant
-%}

<section class="product section" data-product data-main-product data-product-id="{{ product.id }}">
  <div class="page-width">
    <nav class="breadcrumb" aria-label="{{ 'general.breadcrumb' | t }}">
      <a href="{{ routes.root_url }}">Home</a>
      {%- if collection -%}
        {% render 'icon', name: 'chevron-right' %}<a href="{{ collection.url }}">{{ collection.title | escape }}</a>
      {%- endif -%}
      {% render 'icon', name: 'chevron-right' %}<span aria-current="page">{{ product.title | escape }}</span>
    </nav>

    <div class="product__grid">

      {%- comment -%} Galerie {%- endcomment -%}
      <div class="product__gallery" data-gallery>
        <div class="product__main-image">
          {%- if product.featured_media -%}
            {%- for media in product.media -%}
              {%- liquid
                assign img_loading = 'lazy'
                assign img_priority = 'auto'
                if forloop.first
                  assign img_loading = 'eager'
                  assign img_priority = 'high'
                endif
                assign img_alt = media.alt | default: product.title
              -%}
              {{ media
                | image_url: width: 1200
                | image_tag:
                  widths: '480, 750, 1000, 1200',
                  sizes: '(min-width: 990px) 50vw, 100vw',
                  loading: img_loading,
                  fetchpriority: img_priority,
                  class: 'product__img',
                  alt: img_alt
              }}
            {%- endfor -%}
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag: 'product__img placeholder' }}
          {%- endif -%}
        </div>
        {%- if product.media.size > 1 -%}
          <div class="product__thumbs" role="tablist">
            {%- for media in product.media -%}
              {%- assign thumb_alt = media.alt | default: product.title -%}
              <button class="product__thumb{% if forloop.first %} is-active{% endif %}" data-thumb-index="{{ forloop.index0 }}" aria-label="{{ 'products.gallery_image' | t }} {{ forloop.index }}">
                {{ media | image_url: width: 140 | image_tag: loading: 'lazy', alt: thumb_alt }}
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Produkt-Infos {%- endcomment -%}
      <div class="product__info">
        {%- assign rating = product.metafields.reviews.rating.value -%}
        {%- if rating -%}
          <a class="rating" href="#reviews" aria-label="{{ rating.rating }} von 5 Sternen">
            {%- for i in (1..5) -%}
              <span class="rating__star{% if i > rating.rating %} rating__star--empty{% endif %}">{% render 'icon', name: 'star' %}</span>
            {%- endfor -%}
            {%- assign rating_count = product.metafields.reviews.rating_count.value -%}
            {%- if rating_count %}<span class="rating__count">{{ rating_count }} {{ 'products.reviews' | t }}</span>{% endif -%}
          </a>
        {%- endif -%}

        <h1 class="product__title">{{ product.title | escape }}</h1>

        <div data-price-wrapper>
          {% render 'price', variant: current_variant %}
        </div>
        <p class="product__tax-note">{{ 'products.tax_note' | t }}</p>

        {%- if section.settings.usp_list != blank -%}
          <ul class="checklist checklist--compact" role="list">
            {%- assign usps = section.settings.usp_list | split: '|' -%}
            {%- for usp in usps -%}
              <li>{% render 'icon', name: 'check' %} {{ usp | strip | escape }}</li>
            {%- endfor -%}
          </ul>
        {%- endif -%}

        {%- form 'product', product, id: 'ProductForm', class: 'product__form', data-product-form: '' -%}
          <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id>

          {%- unless product.has_only_default_variant -%}
            {%- for option in product.options_with_values -%}
              <fieldset class="variant-picker" data-option-index="{{ forloop.index0 }}">
                <legend class="variant-picker__label">{{ option.name | escape }}: <span data-selected-value>{{ option.selected_value | escape }}</span></legend>
                <div class="variant-picker__values">
                  {%- for value in option.values -%}
                    <label class="variant-pill">
                      <input type="radio" name="option{{ forloop.parentloop.index }}" value="{{ value | escape }}"
                        {% if option.selected_value == value %}checked{% endif %} data-option-input>
                      <span>{{ value | escape }}</span>
                    </label>
                  {%- endfor -%}
                </div>
              </fieldset>
            {%- endfor -%}
          {%- endunless -%}

          <div class="product__buy-row">
            <div class="qty" data-qty>
              <button type="button" class="qty__btn" data-qty-minus aria-label="{{ 'products.quantity_decrease' | t }}">{% render 'icon', name: 'minus' %}</button>
              <input class="qty__input" type="number" name="quantity" value="1" min="1" inputmode="numeric" aria-label="{{ 'products.quantity' | t }}">
              <button type="button" class="qty__btn" data-qty-plus aria-label="{{ 'products.quantity_increase' | t }}">{% render 'icon', name: 'plus' %}</button>
            </div>
            <button type="submit" class="btn btn--accent btn--lg product__atc" data-atc {% unless current_variant.available %}disabled{% endunless %}>
              <span data-atc-text>
                {%- if current_variant.available -%}{{ 'products.add_to_cart' | t }}{%- else -%}{{ 'products.sold_out' | t }}{%- endif -%}
              </span>
            </button>
          </div>
          {{ form | payment_button }}
        {%- endform -%}

        <ul class="product__trust" role="list">
          <li>{% render 'icon', name: 'truck' %} {{ settings.shipping_text | escape }}</li>
          <li>{% render 'icon', name: 'shield' %} {{ settings.guarantee_text | escape }}</li>
          <li>{% render 'icon', name: 'lock' %} {{ 'products.secure_checkout' | t }}</li>
        </ul>

        {%- comment -%} Accordion-Blöcke: Beschreibung, Versand, Garantie, eigene {%- endcomment -%}
        <div class="product__accordions">
          {%- for block in section.blocks -%}
            {%- case block.type -%}
            {%- when 'description' -%}
              <details class="faq__item" {{ block.shopify_attributes }} open>
                <summary class="faq__question">{{ 'products.description' | t }}<span class="faq__chevron">{% render 'icon', name: 'chevron-down' %}</span></summary>
                <div class="faq__answer rte">{{ product.description }}</div>
              </details>
            {%- when 'shipping' -%}
              <details class="faq__item" {{ block.shopify_attributes }}>
                <summary class="faq__question">{{ block.settings.title | escape }}<span class="faq__chevron">{% render 'icon', name: 'chevron-down' %}</span></summary>
                <div class="faq__answer rte">{{ block.settings.content }}</div>
              </details>
            {%- when 'guarantee' -%}
              <details class="faq__item" {{ block.shopify_attributes }}>
                <summary class="faq__question">{{ block.settings.title | escape }}<span class="faq__chevron">{% render 'icon', name: 'chevron-down' %}</span></summary>
                <div class="faq__answer rte">{{ block.settings.content }}</div>
              </details>
            {%- when 'faq' -%}
              <details class="faq__item" {{ block.shopify_attributes }}>
                <summary class="faq__question">{{ block.settings.question | escape }}<span class="faq__chevron">{% render 'icon', name: 'chevron-down' %}</span></summary>
                <div class="faq__answer rte">{{ block.settings.answer }}</div>
              </details>
            {%- endcase -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>

  {%- comment -%} Sticky Add-to-Cart (erscheint, sobald der Haupt-Button aus dem Viewport scrollt) {%- endcomment -%}
  <div class="sticky-atc" data-sticky-atc hidden>
    <div class="page-width sticky-atc__inner">
      {%- if product.featured_image -%}
        {{ product.featured_image | image_url: width: 100 | image_tag: loading: 'lazy', class: 'sticky-atc__img', alt: product.title }}
      {%- endif -%}
      <div class="sticky-atc__meta">
        <span class="sticky-atc__title">{{ product.title | escape }}</span>
        <span class="sticky-atc__price" data-sticky-price>{{ current_variant.price | money }}</span>
      </div>
      <button class="btn btn--accent" data-sticky-atc-btn>{{ 'products.add_to_cart' | t }}</button>
    </div>
  </div>

  {%- comment -%} Variantendaten für JS {%- endcomment -%}
  <script type="application/json" data-variant-json>
    {{ product.variants | json }}
  </script>
</section>

{%- comment -%} Product-Schema (SEO: Rich Snippets mit Preis & Verfügbarkeit) {%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": {{ product.title | json }},
  "url": {{ request.origin | append: product.url | json }},
  {%- if product.featured_image %}"image": {{ product.featured_image | image_url: width: 1200 | prepend: 'https:' | json }},{% endif %}
  "description": {{ product.description | strip_html | truncate: 500 | json }},
  {%- if product.vendor != blank %}"brand": { "@type": "Brand", "name": {{ product.vendor | json }} },{% endif %}
  {%- assign rating = product.metafields.reviews.rating.value -%}
  {%- assign rating_count = product.metafields.reviews.rating_count.value -%}
  {%- if rating and rating_count %}
  "aggregateRating": { "@type": "AggregateRating", "ratingValue": {{ rating.rating | json }}, "reviewCount": {{ rating_count | json }} },
  {%- endif %}
  "offers": [
    {%- for variant in product.variants -%}
    {
      "@type": "Offer",
      "sku": {{ variant.sku | default: variant.id | json }},
      "price": {{ variant.price | divided_by: 100.0 | json }},
      "priceCurrency": {{ cart.currency.iso_code | json }},
      "availability": "{% if variant.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
      "url": {{ request.origin | append: variant.url | json }}
    }{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ]
}
</script>

{% schema %}
{
  "name": "Produktseite",
  "settings": [
    { "type": "text", "id": "usp_list", "label": "Kaufargumente (mit | getrennt)", "default": "Versand mit Sendungsverfolgung|30 Tage Geld-zurück-Garantie|Sichere Bezahlung" }
  ],
  "blocks": [
    { "type": "description", "name": "Beschreibung", "limit": 1, "settings": [] },
    {
      "type": "shipping", "name": "Versand-Info",
      "settings": [
        { "type": "text", "id": "title", "label": "Titel", "default": "Versand & Lieferung" },
        { "type": "richtext", "id": "content", "label": "Inhalt", "default": "<p>Versand aus dem EU-Lager. Lieferzeit 7–14 Tage, immer inkl. Sendungsverfolgung.</p>" }
      ]
    },
    {
      "type": "guarantee", "name": "Garantie",
      "settings": [
        { "type": "text", "id": "title", "label": "Titel", "default": "30 Tage Geld-zurück-Garantie" },
        { "type": "richtext", "id": "content", "label": "Inhalt", "default": "<p>Teste das Produkt 30 Tage. Nicht zufrieden? Schreib uns eine E-Mail und du erhältst dein Geld zurück – ohne Wenn und Aber.</p>" }
      ]
    },
    {
      "type": "faq", "name": "Produkt-FAQ",
      "settings": [
        { "type": "text", "id": "question", "label": "Frage", "default": "Für wen ist das Produkt geeignet?" },
        { "type": "richtext", "id": "answer", "label": "Antwort", "default": "<p>Antwort hier einfügen.</p>" }
      ]
    }
  ]
}
{% endschema %}
