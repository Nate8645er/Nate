{%- comment -%} Suchseite: Suchfeld + Ergebnisgrid mit Pagination {%- endcomment -%}
<section class="search section">
  <div class="page-width">
    <h1 class="page__title">{{ 'search.title' | t }}</h1>

    <form action="{{ routes.search_url }}" method="get" role="search" class="search__form">
      <label class="visually-hidden" for="SearchInput">{{ 'general.search' | t }}</label>
      <input id="SearchInput" type="search" name="q" value="{{ search.terms | escape }}" class="input" placeholder="{{ 'search.placeholder' | t }}" autocomplete="off">
      <button type="submit" class="btn btn--primary" aria-label="{{ 'general.search' | t }}">{% render 'icon', name: 'search' %}</button>
    </form>

    {%- if search.performed -%}
      {%- if search.results_count == 0 -%}
        <div class="empty-state">
          <p>{{ 'search.no_results' | t: terms: search.terms }}</p>
          <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary">{{ 'general.view_all' | t }}</a>
        </div>
      {%- else -%}
        <p class="collection__count">{{ 'search.results_count' | t: count: search.results_count, terms: search.terms }}</p>
        {%- paginate search.results by 12 -%}
          <div class="product-grid product-grid--4">
            {%- for item in search.results -%}
              {%- if item.object_type == 'product' -%}
                {% render 'product-card', card_product: item, lazy: true %}
              {%- else -%}
                <article class="search-result">
                  <h3><a href="{{ item.url }}">{{ item.title | escape }}</a></h3>
                  <p>{{ item.content | strip_html | truncate: 140 }}</p>
                </article>
              {%- endif -%}
            {%- endfor -%}
          </div>
          {%- if paginate.pages > 1 -%}
            <nav class="pagination" aria-label="{{ 'general.pagination' | t }}">
              {%- if paginate.previous -%}<a class="pagination__item" href="{{ paginate.previous.url }}">&larr;</a>{%- endif -%}
              {%- for part in paginate.parts -%}
                {%- if part.is_link -%}
                  <a class="pagination__item" href="{{ part.url }}">{{ part.title }}</a>
                {%- else -%}
                  <span class="pagination__item{% if part.title == paginate.current_page %} is-current{% endif %}">{{ part.title }}</span>
                {%- endif -%}
              {%- endfor -%}
              {%- if paginate.next -%}<a class="pagination__item" href="{{ paginate.next.url }}">&rarr;</a>{%- endif -%}
            </nav>
          {%- endif -%}
        {%- endpaginate -%}
      {%- endif -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Suche",
  "settings": []
}
{% endschema %}
