{%- comment -%}
  Strukturierte Daten (JSON-LD) für SEO:
  - Organization + WebSite (mit SearchAction) auf der Startseite
  - BreadcrumbList auf Produkt- und Kategorieseiten
  - Product-Schema liegt in sections/main-product.liquid (braucht Variantendaten)
  - FAQPage-Schema liegt in sections/faq.liquid
{%- endcomment -%}
{%- if request.page_type == 'index' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": {{ shop.name | json }},
  "url": {{ request.origin | json }},
  {%- if settings.logo %}"logo": {{ settings.logo | image_url: width: 500 | prepend: 'https:' | json }},{% endif %}
  "sameAs": [
    {%- assign social_links = '' -%}
    {%- if settings.social_instagram != blank %}{{ settings.social_instagram | json }}{%- assign social_links = 'x' -%}{% endif %}
    {%- if settings.social_facebook != blank %}{% if social_links != '' %},{% endif %}{{ settings.social_facebook | json }}{%- assign social_links = 'x' -%}{% endif %}
    {%- if settings.social_tiktok != blank %}{% if social_links != '' %},{% endif %}{{ settings.social_tiktok | json }}{%- assign social_links = 'x' -%}{% endif %}
    {%- if settings.social_youtube != blank %}{% if social_links != '' %},{% endif %}{{ settings.social_youtube | json }}{% endif %}
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "customer service",
    "email": {{ shop.email | json }}
  }
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": {{ shop.name | json }},
  "url": {{ request.origin | json }},
  "potentialAction": {
    "@type": "SearchAction",
    "target": "{{ request.origin }}/search?q={search_term_string}",
    "query-input": "required name=search_term_string"
  }
}
</script>
{%- endif -%}

{%- if request.page_type == 'product' or request.page_type == 'collection' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": {{ request.origin | json }} }
    {%- if request.page_type == 'collection' -%}
    ,{ "@type": "ListItem", "position": 2, "name": {{ collection.title | json }}, "item": {{ request.origin | append: collection.url | json }} }
    {%- endif -%}
    {%- if request.page_type == 'product' -%}
      {%- if collection -%}
      ,{ "@type": "ListItem", "position": 2, "name": {{ collection.title | json }}, "item": {{ request.origin | append: collection.url | json }} }
      ,{ "@type": "ListItem", "position": 3, "name": {{ product.title | json }}, "item": {{ request.origin | append: product.url | json }} }
      {%- else -%}
      ,{ "@type": "ListItem", "position": 2, "name": {{ product.title | json }}, "item": {{ request.origin | append: product.url | json }} }
      {%- endif -%}
    {%- endif -%}
  ]
}
</script>
{%- endif -%}
