# --- JARVIS configuration (all optional; configure what you use) ---------------
# Copy to .env — never commit real keys.

# LLM providers (any one is enough; local Ollama/LM Studio need no key)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=

# Core settings (env overrides config.yaml; nesting via __)
# JARVIS_LLM__DEFAULT_PROVIDER=ollama
# JARVIS_LLM__PREFER_LOCAL=true
# JARVIS_API__AUTH_TOKEN=change-me
# JARVIS_VOICE__ENABLED=true
# JARVIS_DATA_DIR=~/.jarvis

# Integrations (tools appear only when configured)
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_IMAP_HOST=

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

DISCORD_WEBHOOK_URL=
DISCORD_BOT_TOKEN=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

GITHUB_TOKEN=
NOTION_TOKEN=
GOOGLE_OAUTH_TOKEN=
MSGRAPH_ACCESS_TOKEN=

WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
