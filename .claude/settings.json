{
  "extraKnownMarketplaces": {
    "nate-marketplace": {
      "source": {
        "source": "github",
        "repo": "Nate8645er/Nate"
      }
    }
  },
  "enabledPlugins": {
    "ultra-enterprise-os@nate-marketplace": true
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/install_jarvis.sh"
          }
        ]
      }
    ]
  }
}
