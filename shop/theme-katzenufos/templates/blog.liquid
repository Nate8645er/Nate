<h1 class="section-title">{{ blog.title }}</h1>
{% paginate blog.articles by 12 %}
  <div class="grid">
    {% for article in blog.articles %}
      <div class="card">
        <a href="{{ article.url }}">
          {% if article.image %}
            <img src="{{ article.image | image_url: width: 600 }}" alt="{{ article.title | escape }}" loading="lazy">
          {% endif %}
          <div class="card-body">
            <h3>{{ article.title }}</h3>
            <p>{{ article.excerpt_or_content | strip_html | truncate: 120 }}</p>
          </div>
        </a>
      </div>
    {% else %}
      <p>Noch keine Artikel vorhanden.</p>
    {% endfor %}
  </div>
  {% if paginate.pages > 1 %}
    <div class="pagination">{{ paginate | default_pagination }}</div>
  {% endif %}
{% endpaginate %}
