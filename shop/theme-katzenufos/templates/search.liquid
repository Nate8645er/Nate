<h1 class="section-title">Suche</h1>
<form action="{{ routes.search_url }}" method="get">
  <input type="text" name="q" value="{{ search.terms | escape }}" placeholder="Wonach suchst du?" style="padding:12px;border-radius:10px;border:1px solid #ddd;width:70%">
  <button type="submit" class="btn">Suchen</button>
</form>

{% if search.performed %}
  {% paginate search.results by 24 %}
    <h2 class="section-title">{{ search.results_count }} Treffer für „{{ search.terms | escape }}"</h2>
    <div class="grid">
      {% for item in search.results %}
        <div class="card">
          <a href="{{ item.url }}">
            {% if item.featured_image %}
              <img src="{{ item.featured_image | image_url: width: 600 }}" alt="{{ item.title | escape }}" loading="lazy">
            {% endif %}
            <div class="card-body">
              <h3>{{ item.title }}</h3>
            </div>
          </a>
        </div>
      {% endfor %}
    </div>
    {% if paginate.pages > 1 %}
      <div class="pagination">{{ paginate | default_pagination }}</div>
    {% endif %}
  {% endpaginate %}
{% endif %}
