# AI Command Center – Umgebungsvariablen (Kopie als .env anlegen)
# Secrets NIE committen (.env* ist per .gitignore ausgeschlossen).

# LLM-Anbieter (mindestens einer erforderlich fuer Missionen)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MOONSHOT_API_KEY=

# Modell-Rat: zusaetzliche Frontier-Modelle als Worker unter dem Boss (Fable 5).
# Jedes Modell ist erst einsatzbereit, sobald sein Key (bzw. bei Llama die URL)
# gesetzt ist – sonst zeigt /team es ehrlich als "API-Key hinterlegen".
# Alle sind OpenAI-kompatibel. Die exakte Modell-ID ist optional per
# <PROVIDER>_MODEL ueberschreibbar (z. B. GOOGLE_MODEL=gemini-3-ultra).
GOOGLE_API_KEY=       # Gemini 3 Ultra (Google)
XAI_API_KEY=          # Grok 5 (xAI)
QWEN_API_KEY=         # Qwen 3 Max (Alibaba DashScope)
DEEPSEEK_API_KEY=     # DeepSeek R2
MISTRAL_API_KEY=      # Mistral Magistral
# Meta Llama hat keine erste-Partei-API: URL eines OpenAI-kompatiblen Hosts
# (Together/Fireworks/Groq/eigener vLLM) setzen, Key optional.
META_LLM_URL=         # Llama 4 Behemoth – Endpoint des Hosts
META_API_KEY=
# Optionale Modell-ID-Overrides (Standardwerte siehe lib/agents/council.ts):
# GOOGLE_MODEL=  XAI_MODEL=  QWEN_MODEL=  DEEPSEEK_MODEL=  MISTRAL_MODEL=  META_MODEL=

# Optional: lokales/eigenes Modell (OpenAI-kompatibel, z. B. Ollama/vLLM/LM Studio).
# Sobald LOCAL_LLM_URL gesetzt ist, steht der Provider "local" als Fallback bereit
# – so laufen lokale UND Cloud-Modelle nebeneinander. Beispiel Ollama:
#   LOCAL_LLM_URL=http://127.0.0.1:11434/v1/chat/completions
#   LOCAL_LLM_MODEL=llama3.1
# LOCAL_LLM_API_KEY nur setzen, falls der lokale Server einen Key verlangt.
LOCAL_LLM_URL=
LOCAL_LLM_MODEL=
LOCAL_LLM_API_KEY=

# Signatur-Secret fuer Lizenzschluessel/-Token (Produktion: PFLICHT).
# Muss zu den ausgegebenen Schluesseln passen – aendern macht alle ungueltig.
LICENSE_SECRET=

# Optional: separates Passwort fuer die Admin-Seite /admin (Schluessel-Generator).
# Nicht gesetzt => es gilt LICENSE_SECRET als Admin-Passwort (kein Zusatz-Setup noetig).
ADMIN_SECRET=

# --- Zahlung: Stripe (Abo-Checkout + Kundenportal) --------------------------
# Ohne STRIPE_SECRET_KEY bleiben Checkout/Portal ehrlich "nicht konfiguriert".
# Test-Keys beginnen mit sk_test_, Live-Keys mit sk_live_.
STRIPE_SECRET_KEY=
# Signing-Secret des Webhook-Endpunkts (/api/stripe/webhook), Format whsec_...
# In Stripe unter Entwickler > Webhooks anlegen und Ereignisse abonnieren:
# checkout.session.completed, customer.subscription.updated/.deleted
STRIPE_WEBHOOK_SECRET=

# --- Login: Supabase (Kundenkonto) ------------------------------------------
# Ohne diese Werte bleibt der Login ehrlich "nicht konfiguriert".
# Anon-Key ist bewusst oeffentlich (NEXT_PUBLIC_*); Schutz via Row-Level-Security.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-Role-Key: SERVERSEITIGES GEHEIMNIS (umgeht RLS). Fuer Plan-Freischaltung
# nach Stripe-Webhook und Portal-Lookup. NIE NEXT_PUBLIC_, nie an den Client.
# Tabelle vorab anlegen: supabase/schema.sql im Supabase-SQL-Editor ausfuehren.
SUPABASE_SERVICE_ROLE_KEY=

# Oeffentliche App-URL (z. B. https://ihr-shop.ch) fuer sichere Redirect-/
# Return-URLs (Portal). Ohne Wert wird der Request-Origin genutzt.
APP_URL=

# --- Rate-Limiting: Upstash Redis (empfohlen fuer Produktion) ----------------
# Ohne diese Werte greift ein Best-Effort-In-Memory-Limiter (nur pro Instanz).
# Mit Upstash zaehlt das Limit ueber alle Serverless-Instanzen hinweg.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- E-Mail: Resend (Willkommens-/Lizenz-Mail nach dem Kauf) -----------------
# Ohne diese Werte wird keine Mail versendet (Schluessel bleibt im Konto abrufbar).
# MAIL_FROM muss eine in Resend verifizierte Absenderadresse/Domain sein.
RESEND_API_KEY=
MAIL_FROM=
