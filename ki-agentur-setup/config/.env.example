# =============================================================================
#  .env.example  -  Zentrale API-Keys / Konfiguration der KI-Agentur
#  Kopieren nach .env und Werte eintragen. NIEMALS echte Keys committen!
# =============================================================================

# --- LLM-Provider (fuer CrewAI, browser-use, bolt.diy etc.) ------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=

# --- OmniRoute als zentrales Gateway (empfohlen) -----------------------------
# Wenn OmniRoute laeuft, koennen alle Tools ueber EINEN Endpoint gehen:
#   OpenAI-kompatibel -> Base-URL unten, Modell "auto"
OMNIROUTE_BASE_URL=http://localhost:20128/v1
OMNIROUTE_API_KEY=

# --- ComfyUI / MCP -----------------------------------------------------------
COMFYUI_URL=http://127.0.0.1:8188
COMFYUI_MCP_URL=http://127.0.0.1:9000/mcp

# --- n8n ---------------------------------------------------------------------
N8N_PORT=5678
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=

# --- Metabase ----------------------------------------------------------------
MB_JETTY_PORT=3000
