<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="#07070d">
    <link rel="canonical" href="{{ canonical_url }}">
    <title>
      {{ page_title }}{% if current_tags %} &ndash; {{ current_tags | join: ', ' }}{% endif %}{% unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}
    </title>
    {% if page_description %}<meta name="description" content="{{ page_description | escape }}">{% endif %}
    {{ content_for_header }}
    {{ 'theme.css' | asset_url | stylesheet_tag }}
  </head>
  <body class="tpl-{{ template | replace: '.', '-' | handle }}">
    <header class="hd">
      <div class="wrap hd-in">
        <a href="{{ routes.root_url }}" class="hd-logo">AI <span>Command Center</span></a>
        <nav class="hd-nav">
          <a href="{{ routes.root_url }}pages/preise">Preise</a>
          <a href="{{ routes.root_url }}pages/so-funktionierts">So funktioniert's</a>
          <a href="{{ routes.root_url }}pages/anwendungsfaelle">Anwendungsfälle</a>
          <a href="{{ routes.root_url }}pages/branchen">Branchen</a>
          <a href="{{ routes.root_url }}pages/ratgeber">Ratgeber</a>
          <a href="{{ routes.root_url }}#faq">FAQ</a>
          {% if shop.customer_accounts_enabled %}<a href="{{ routes.account_url }}">Konto</a>{% endif %}
        </nav>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn-sm">Jetzt starten</a>
      </div>
    </header>

    <main id="main">{{ content_for_layout }}</main>

    <footer class="ft">
      <div class="wrap ft-grid">
        <div class="ft-brand">
          <p class="ft-logo">AI <span>Command Center</span></p>
          <p class="ft-tag">Ihre komplette KI-Abteilung als SaaS – für Einzelunternehmer bis Grosskonzern.</p>
        </div>
        <div class="ft-col">
          <h4>Produkt</h4>
          <a href="{{ routes.root_url }}pages/preise">Preise</a>
          <a href="{{ routes.root_url }}pages/so-funktionierts">So funktioniert's</a>
          <a href="{{ routes.root_url }}pages/anwendungsfaelle">Anwendungsfälle</a>
          <a href="{{ routes.root_url }}pages/branchen">Branchen</a>
          <a href="{{ routes.root_url }}pages/integrationen">Integrationen</a>
          <a href="{{ routes.root_url }}pages/vergleich">Agentur-Vergleich</a>
          <a href="{{ routes.all_products_collection_url }}">Alle Pakete</a>
        </div>
        <div class="ft-col">
          <h4>Unternehmen</h4>
          <a href="{{ routes.root_url }}pages/ueber-uns">Über uns</a>
          <a href="{{ routes.root_url }}pages/ratgeber">Ratgeber</a>
          <a href="{{ routes.root_url }}pages/wissen">Wissen</a>
          <a href="{{ routes.root_url }}pages/warum">Wieso &amp; Warum</a>
          <a href="{{ routes.root_url }}pages/sicherheit">Sicherheit</a>
          <a href="{{ routes.root_url }}pages/keine-bewertungen">Keine Bewertungen</a>
          <a href="{{ routes.root_url }}pages/wissen">Wissen</a>
          <a href="{{ routes.root_url }}pages/support">Hilfe &amp; Support</a>
          <a href="{{ routes.root_url }}pages/demo">Live-Demo</a>
          <a href="{{ routes.root_url }}pages/kontakt">Kontakt</a>
          {% if shop.customer_accounts_enabled %}<a href="{{ routes.account_url }}">Mein Konto</a>{% endif %}
        </div>
        <div class="ft-col">
          <h4>Rechtliches</h4>
          <a href="{{ routes.root_url }}policies/privacy-policy">Datenschutz</a>
          <a href="{{ routes.root_url }}policies/terms-of-service">AGB</a>
          <a href="{{ routes.root_url }}policies/refund-policy">Rückerstattung</a>
        </div>
      </div>
      <div class="wrap ft-bar">
        <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }} · Ihre KI-Abteilung ab Tag 1.</p>
        <p class="ft-pay">Sichere Zahlung · Schweizer Anbieter</p>
      </div>
    </footer>
  </body>
</html>
