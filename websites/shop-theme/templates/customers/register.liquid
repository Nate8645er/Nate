<div class="page"><h1>Konto erstellen</h1>
{% form 'create_customer' %}
  <input type="text" name="customer[first_name]" placeholder="Vorname">
  <input type="text" name="customer[last_name]" placeholder="Nachname">
  <input type="email" name="customer[email]" placeholder="E-Mail" required>
  <input type="password" name="customer[password]" placeholder="Passwort" required>
  <button class="btn" type="submit">Registrieren</button>
{% endform %}</div>
