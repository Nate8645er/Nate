    <div class="hero-cta">
      <a href="#pakete" class="btn">Pakete ansehen</a>
      <a href="{{ routes.all_products_collection_url }}" class="btn btn-ghost">Zum Shop</a>
    </div>
    <div class="hero-badges">
      <span>✓ Sofort startklar</span><span>✓ Ihre Firma verbunden</span><span>✓ Echte Ergebnisse</span>
    </div>
  </div>
</section>

