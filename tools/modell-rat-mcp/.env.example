# Modell-Rat – Zugänge (Kopie als .env in DIESEM Ordner anlegen und ausfüllen).
# WICHTIG: Die .env ist per .gitignore ausgeschlossen – Keys NIE committen,
# NIE in den Chat schreiben. Nur die Zugänge eintragen, die du nutzen willst;
# der Rest bleibt ehrlich "nicht konfiguriert".

# ─── EMPFOHLEN: EIN Key für ALLE Modelle (OpenRouter) ──────────────────────
# Ein einziger Key schaltet alle Worker frei (GPT, Claude, Gemini, Grok, Kimi,
# DeepSeek, Qwen, Llama, Mistral, GLM, Phi, Command, Nemotron). Key holen:
# https://openrouter.ai/keys – Modelle/Preise: https://openrouter.ai/models.
# Reicht das, brauchst du die Einzel-Keys unten NICHT. (Ein gesetzter
# Einzel-Key hat trotzdem Vorrang.)
OPENROUTER_API_KEY=

# ─── ODER Einzel-Zugänge pro Anbieter (nur nötig ohne OpenRouter) ──────────
OPENAI_API_KEY=       # GPT-5.6 Sol Ultra        – https://platform.openai.com/api-keys
ANTHROPIC_API_KEY=    # Claude Opus 4.8 / Fable 5– https://console.anthropic.com/settings/keys
GOOGLE_API_KEY=       # Gemini 3.1 Pro Ultra     – https://aistudio.google.com/apikey
XAI_API_KEY=          # Grok 4.5 Heavy           – https://console.x.ai
MOONSHOT_API_KEY=     # Kimi K3                  – https://platform.moonshot.ai
DEEPSEEK_API_KEY=     # DeepSeek V4 Pro          – https://platform.deepseek.com/api_keys
QWEN_API_KEY=         # Qwen 3.8 Max             – https://modelstudio.console.alibabacloud.com
MISTRAL_API_KEY=      # Mistral Large 3          – https://console.mistral.ai/api-keys
ZHIPU_API_KEY=        # GLM-5 (Zhipu AI)         – https://open.bigmodel.cn
COHERE_API_KEY=       # Command A+               – https://dashboard.cohere.com/api-keys
NVIDIA_API_KEY=       # Nemotron Ultra (NIM)     – https://build.nvidia.com

# Llama 4 Maverick (Meta) hat keine eigene API: Endpoint eines OpenAI-
# kompatiblen Hosts (Together/Fireworks/Groq/eigener vLLM) setzen, Key optional.
META_LLM_URL=         # z. B. https://api.together.xyz/v1/chat/completions
META_API_KEY=

# Phi-4 (Microsoft) ist offen: entweder Host-URL (eigener vLLM/Ollama) ODER
# GitHub-Models/Azure-AI-Inference-Endpoint + Key.
PHI_URL=              # z. B. https://models.inference.ai.azure.com/chat/completions
PHI_API_KEY=

# Optional: exakte Modell-ID überschreiben (sobald die Zielversion live ist).
# OPENAI_MODEL=   ANTHROPIC/SONNET_MODEL=   GOOGLE_MODEL=   XAI_MODEL=
# MOONSHOT_MODEL=   DEEPSEEK_MODEL=   QWEN_MODEL=   MISTRAL_MODEL=   META_MODEL=
# ZHIPU_MODEL=   PHI_MODEL=   COHERE_MODEL=   NVIDIA_MODEL=
