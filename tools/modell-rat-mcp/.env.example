# Modell-Rat – Zugänge (Kopie als .env in DIESEM Ordner anlegen und ausfüllen).
# WICHTIG: Die .env ist per .gitignore ausgeschlossen – Keys NIE committen,
# NIE in den Chat schreiben. Nur die Zugänge eintragen, die du nutzen willst;
# der Rest bleibt ehrlich "nicht konfiguriert".

GOOGLE_API_KEY=       # Gemini 3 Ultra   – https://aistudio.google.com/apikey
XAI_API_KEY=          # Grok 5           – https://console.x.ai
MOONSHOT_API_KEY=     # Kimi (Moonshot)  – https://platform.moonshot.ai
QWEN_API_KEY=         # Qwen 3 Max       – https://modelstudio.console.alibabacloud.com
DEEPSEEK_API_KEY=     # DeepSeek R2      – https://platform.deepseek.com/api_keys
OPENAI_API_KEY=       # ChatGPT (GPT)    – https://platform.openai.com/api-keys
ANTHROPIC_API_KEY=    # Claude Sonnet 5  – https://console.anthropic.com/settings/keys
MISTRAL_API_KEY=      # Mistral Magistral– https://console.mistral.ai/api-keys

# Llama 4 Behemoth (Meta) hat keine eigene API: Endpoint eines OpenAI-
# kompatiblen Hosts (Together/Fireworks/Groq/eigener vLLM) setzen, Key optional.
META_LLM_URL=         # z. B. https://api.together.xyz/v1/chat/completions
META_API_KEY=

# Optional: exakte Modell-ID überschreiben, falls sie vom Standard abweicht.
# GOOGLE_MODEL=gemini-3-ultra
# MOONSHOT_MODEL=kimi-k3
# XAI_MODEL=grok-5
# QWEN_MODEL=qwen3-max
# DEEPSEEK_MODEL=deepseek-reasoner
# MISTRAL_MODEL=magistral-medium-latest
# META_MODEL=llama-4-behemoth
