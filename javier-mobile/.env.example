# JAVIER MOBILE - Konfiguration
# Diese Datei nach .env kopieren und Werte eintragen.

# Pflicht: Anthropic API-Key (sonst fragt server.py beim Start danach)
ANTHROPIC_API_KEY=

# Optional: Modell fuer JAVIER (Boss + Synthese der Holding).
# Standard: claude-fable-5 (Fable 5). Hat dein Key darauf keinen
# Zugriff, faellt JAVIER automatisch auf claude-sonnet-4-6 zurueck -
# du musst hier also nichts tun.
JAVIER_MODEL=

# Optional: OpenAI-Key fuer die Worker-Agents der Milliarden-Holding
# (GPT-5.6-Sol). Ohne Key laufen die Worker ebenfalls ueber Claude -
# JAVIER funktioniert also auch komplett ohne OpenAI.
OPENAI_API_KEY=
JAVIER_SOL_MODEL=
# Reasoning-Stufe des Sol-Workers (Standard: ultra, wie im Codex-Setup)
JAVIER_SOL_EFFORT=

# Empfohlen bei Cloud-Betrieb (oeffentliche URL): einfaches Passwort,
# das die App beim ersten Start einmalig abfragt. Ohne Passwort koennte
# jeder mit der URL auf deine Kosten chatten.
JAVIER_PASSWORD=

# Optional: Shopify read-only Status fuer MeowUfo
# SHOPIFY_STORE ist die myshopify-Domain, z.B. meowufo.myshopify.com
SHOPIFY_STORE=
SHOPIFY_ACCESS_TOKEN=

# Optional: Instagram Graph API (nur wenn beide gesetzt sind, bekommt
# JAVIER das Tool publish_instagram_post - siehe README.md)
IG_ACCESS_TOKEN=
IG_BUSINESS_ID=

# Optional: eigene Programme fuer den Desktop-Modus ("JAVIER, starte
# Spotify"). Format wie CONTACTS/APPS - Name=Pfad-zur-Exe oder URL-Scheme:
# PROGRAMS=Spotify=C:\Users\Nate\AppData\Roaming\Spotify\Spotify.exe, Steam=steam://open/main
PROGRAMS=

# Optional: eigene KI-Stimme via ElevenLabs (elevenlabs.io).
# Sind beide gesetzt, spricht JAVIER mit dieser Stimme statt der
# iPhone-Systemstimme. Key: elevenlabs.io -> Profil -> API Keys.
# Voice ID: in der Voice Library bei der gewuenschten Stimme.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
