# JAVIER MOBILE - Konfiguration
# Diese Datei nach .env kopieren und Werte eintragen.

# Pflicht: Anthropic API-Key (sonst fragt server.py beim Start danach)
ANTHROPIC_API_KEY=

# Empfohlen bei Cloud-Betrieb (oeffentliche URL): einfaches Passwort,
# das die App beim ersten Start einmalig abfragt. Ohne Passwort koennte
# jeder mit der URL auf deine Kosten chatten.
JAVIER_PASSWORD=

# Optional: Shopify read-only Status fuer MeowUfo
# SHOPIFY_STORE ist die myshopify-Domain, z.B. meowufo.myshopify.com
SHOPIFY_STORE=
SHOPIFY_ACCESS_TOKEN=

# Optional: Instagram Graph API (nur wenn beide gesetzt sind, bekommt
# JAVIER das Tool publish_instagram_post - siehe README.md)
IG_ACCESS_TOKEN=
IG_BUSINESS_ID=

# Optional: eigene KI-Stimme via ElevenLabs (elevenlabs.io).
# Sind beide gesetzt, spricht JAVIER mit dieser Stimme statt der
# iPhone-Systemstimme. Key: elevenlabs.io -> Profil -> API Keys.
# Voice ID: in der Voice Library bei der gewuenschten Stimme.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
