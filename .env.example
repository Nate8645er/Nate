# JARVIS AI OS — Konfiguration (nach .env kopieren und anpassen)

# Server
JARVIS_HOST=127.0.0.1
JARVIS_PORT=8765

# Identität
JARVIS_ASSISTANT_NAME=Jarvis
JARVIS_WAKE_WORD=jarvis
JARVIS_LANGUAGE=de

# LLM (auto probiert: Anthropic -> OpenAI -> Ollama -> Echo)
JARVIS_LLM_PROVIDER=auto
JARVIS_ANTHROPIC_API_KEY=
JARVIS_ANTHROPIC_MODEL=claude-sonnet-5
JARVIS_OPENAI_API_KEY=
JARVIS_OPENAI_BASE_URL=https://api.openai.com/v1
JARVIS_OPENAI_MODEL=gpt-4o
JARVIS_OLLAMA_BASE_URL=http://localhost:11434
JARVIS_OLLAMA_MODEL=llama3.1

# Memory
JARVIS_VECTOR_BACKEND=auto
JARVIS_QDRANT_URL=http://localhost:6333

# Voice
JARVIS_VOICE_ENABLED=true
JARVIS_STT_MODEL=small
JARVIS_TTS_VOICE=de_DE-thorsten-medium

# Sicherheit: 0 = alles fragen, 1 = ab Schreibzugriff fragen,
# 2 = ab Systemzugriff fragen, 3 = nie fragen (nicht empfohlen)
JARVIS_APPROVAL_THRESHOLD=1
