# platform-backend — Umgebungsvariablen (Beispiel). KEINE echten Secrets hier.
# Alle sind optional: fehlt eine, meldet der Dienst das ehrlich ("nicht
# konfiguriert") und laeuft im jeweils reduzierten Modus weiter.

# Betrieb
PLATFORM_ENV=production                 # development | production

# Auth (Keycloak/OIDC, §3). Issuer = Realm-URL. Audience in PROD erzwingen
# (Client-Audience-Mapper in Keycloak setzen) — siehe SECURITY-REVIEW.md.
KEYCLOAK_ISSUER=https://auth.example.com/realms/ki
KEYCLOAK_AUDIENCE=acc-web

# Datenbank — WICHTIG: Rolle mit NOBYPASSRLS und KEIN Superuser (RLS!).
DATABASE_URL=postgresql://app_user:CHANGE_ME@postgres:5432/platform

# Cache / Rate-Limit
REDIS_URL=redis://redis:6379/0

# Vektor-DB (RAG)
QDRANT_URL=http://qdrant:6333

# Durable Workflows (optional)
TEMPORAL_ADDRESS=temporal:7233

# Objektspeicher (optional)
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME

# Lokale Inferenz (Ollama/vLLM/LM-Studio, OpenAI-kompatibel). Ohne dies laufen
# Missionen nicht (ehrlich 503) bzw. der Router weicht in die Cloud aus.
LOCAL_LLM_URL=http://ollama:11434/v1

# Observability (optional): gesetzt aktiviert OTEL-Tracing.
OTEL_EXPORTER_OTLP_ENDPOINT=
