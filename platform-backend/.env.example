# Platform Backend (Produkt A) — Konfiguration.
# Nach .env kopieren und ausfuellen. .env ist in .gitignore und wird NIE committet.
# Keine bekannten Default-Werte im Compose: fehlt eine Pflicht-Variable,
# schlaegt der Start bewusst fehl (fail-closed).

# --- Datenbank ---
# Superuser fuer Migrationen (DDL + Rollen/Grants).
POSTGRES_PASSWORD=
# Passwort der eingeschraenkten Laufzeit-Rolle app_rw (RLS-gebunden).
APP_DB_PASSWORD=
#
# Fuer Betrieb OHNE Compose (z.B. gegen Supabase) direkt setzen:
#   DATABASE_URL         = Laufzeit-Rolle (NOSUPERUSER, NOBYPASSRLS, nicht Owner)
#   MIGRATE_DATABASE_URL = privilegierte Rolle fuer Migrationen
# DATABASE_URL=postgresql://app_rw:...@host:5432/platform
# MIGRATE_DATABASE_URL=postgresql://postgres:...@host:5432/platform

# --- LiteLLM-Gateway ---
LITELLM_BASE_URL=http://localhost:4000
LITELLM_MASTER_KEY=

# --- Modell-Anbieter (nur setzen, was der Tarif-Katalog nutzt) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# --- Provisionierung/Admin ---
# Schuetzt POST /admin/provision. Langen Zufallswert waehlen.
ADMIN_TOKEN=

# --- Betrieb ---
AUTO_MIGRATE=false
CORS_ORIGINS=
REQUEST_TIMEOUT_S=120
