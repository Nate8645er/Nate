# Platform Backend (Produkt A) — Konfiguration.
# Nach .env kopieren und ausfuellen. .env ist in .gitignore und wird NIE committet.

# --- Datenbank (Supabase-kompatibel: einfach die Supabase-Connection-URL) ---
DATABASE_URL=postgresql://platform:platform@localhost:5432/platform
POSTGRES_PASSWORD=platform

# --- LiteLLM-Gateway ---
LITELLM_BASE_URL=http://localhost:4000
LITELLM_MASTER_KEY=sk-local-dev

# --- Modell-Anbieter (nur setzen, was der Tarif-Katalog nutzt) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# --- Provisionierung/Admin ---
# Schuetzt POST /admin/provision. Langen Zufallswert waehlen.
ADMIN_TOKEN=

# --- Betrieb ---
AUTO_MIGRATE=false
CORS_ORIGINS=
REQUEST_TIMEOUT_S=120
